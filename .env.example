# 运行环境：development / staging / production
APP_ENV=development

# 日志级别：DEBUG / INFO / WARNING / ERROR
APP_LOG_LEVEL=INFO
# 日志目录：按小时轮转，app.log 全部级别，error.log 仅 ERROR
APP_LOG_DIR=./logs

# OceanBase/MySQL 连接串（可选）
# 格式：mysql+aiomysql://user:pass@host:port/db  或 sqlite+aiosqlite:///./app.db
APP_DATABASE_URL=mysql+aiomysql://user:pass@localhost:2881/your_db

# 缠论分析记忆库（快照 + AI + 回填；与 APP_DATABASE_URL 独立）
# SQLite 示例：sqlite:///./data/analysis.db  或裸路径 ./data/analysis.db
APP_ANALYSIS_DB_URL=sqlite:///./data/analysis.db
# technical 完成后默认写入分析库（也可用 CLI --save / API save=true）
# APP_ANALYSIS_SAVE=true

# Redis 地址（队列/缓存，可选）
APP_REDIS_URL=redis://localhost:6379/0

# 上游 LLM 服务密钥（调用外部模型时必填）
APP_LLM_API_KEY=<your-api-key>

# LLM Provider：aliyun（阿里云通义千问）或 deepseek
APP_LLM_PROVIDER=aliyun
# 模型名：阿里云如 qwen-plus；DeepSeek 如 deepseek-chat、deepseek-reasoner
APP_LLM_MODEL=qwen-plus
# 阿里云地域：cn / intl / finance（DeepSeek 可忽略）
APP_LLM_REGION=cn
# DeepSeek 或自建兼容网关：留空则用官方 https://api.deepseek.com/v1/chat/completions
# APP_LLM_BASE_URL=https://api.deepseek.com
APP_LLM_TIMEOUT=600

# 签名/会话密钥（生产必填，仅通过环境变量注入）
APP_SECRET_KEY=<your-secret-key>

# API 鉴权：合法 API Key 列表，逗号分隔（开发可留空或填占位）
APP_API_KEYS=

# 百度千帆搜索（AppBuilder）：API Key、请求超时秒数
APP_BAIDU_API_KEY=<your-baidu-api-key>
APP_BAIDU_SEARCH_TIMEOUT=30

# 目录读取工具：若设置则仅允许列出该根目录下的路径（防目录穿越），空表示不限制
# APP_TOOLS_DIRECTORY_READ_ROOT=./data/files

# 深度调研 Demo：报告输出根目录（每次运行在其下创建子目录）
APP_DEEP_RESEARCH_OUTPUT_DIR=./data/deep_research
# CrewAI：服务端无 TTY 时建议设 true，关闭 "Would you like to view your execution traces?" 等交互提示（代码中 deep_research 流程已自动设置）
# CREWAI_TESTING=true

# 应用服务端口
APP_PORT=8071
